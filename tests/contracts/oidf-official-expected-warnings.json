[
  {
    "test-name": "oidcc-3rd_party-init-login",
    "variant": {"client_auth_type":"client_secret_basic","response_type":"code","server_metadata":"discovery","client_registration":"dynamic_client","response_mode":"default"},
    "configuration-filename": "oidf-oidcc-third-party-init-plan-config.json",
    "current-block": "Unregister dynamically registered client",
    "condition": "UnregisterDynamicallyRegisteredClient",
    "expected-result": "warning",
    "comment": "RFC 7592 permits rotating the registration access token on a client read. This upstream module does not adopt the rotated token before its best-effort cleanup DELETE; product onboarding cleanup independently removes the run-scoped client."
  },
  {
    "test-name": "fapi-ciba-id1",
    "variant": {"client_auth_type":"private_key_jwt","ciba_mode":"ping","fapi_ciba_profile":"plain_fapi","client_registration":"static_client"},
    "configuration-filename": "oidf-fapi-ciba-plain-private-key-jwt-ping-plan-config.json",
    "current-block": "Verify notification callback",
    "condition": "EnsureIncomingTls13",
    "expected-result": "warning",
    "comment": "Official suite public callback ingress currently negotiates TLS 1.2 for CIBA ping callbacks; the implementation separately proves TLS 1.3 client support and still requires BCP 195 TLS 1.2 or TLS 1.3."
  },
