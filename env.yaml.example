BIND: "0.0.0.0:8000"
DATABASE_URL: "postgresql://postgres:postgres@127.0.0.1:5432/oauth"
VALKEY_URL: "redis://127.0.0.1:6379/0"
ISSUER: "http://127.0.0.1:8000"
FRONTEND_BASE_URL: "http://127.0.0.1:3000"
CORS_ALLOWED_ORIGINS:
  - "http://127.0.0.1:3000"
DEFAULT_AUDIENCE: "resource://default"
SESSION_COOKIE_NAME: "nazo_oauth_session"
CSRF_COOKIE_NAME: "nazo_oauth_csrf"
SESSION_TTL_SECONDS: 28800
AUTH_CODE_TTL_SECONDS: 300
ACCESS_TOKEN_TTL_SECONDS: 300
ID_TOKEN_TTL_SECONDS: 600
REFRESH_TOKEN_TTL_SECONDS: 2592000
AVATAR_MAX_BYTES: 2097152
CLIENT_DELIVERY_TTL_SECONDS: 86400
EMAIL_CODE_DEV_RESPONSE_ENABLED: false
AVATAR_STORAGE_DIR: "runtime/avatars"
JWK_KEYS_DIR: "runtime/keys"
RUST_LOG: "info"
