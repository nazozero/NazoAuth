+async def read_authoritative_terminal_info(
+    get_module_info,
+    module_id,
+    *,
+    timeout_seconds=120.0,
+    poll_interval_seconds=1.0,
+):
+    if timeout_seconds <= 0:
+        raise ValueError("timeout_seconds must be greater than zero")
+    if poll_interval_seconds < 0:
+        raise ValueError("poll_interval_seconds must not be negative")
+
+    deadline = time.monotonic() + timeout_seconds
+    last_status = None
+    while True:
+        remaining = deadline - time.monotonic()
+        if remaining <= 0:
+            raise TimeoutError(
+                f"OIDF module {module_id} did not expose terminal info within "
+                f"{timeout_seconds:g}s (last status: {last_status!r})"
+            )
+        try:
+            info = await asyncio.wait_for(get_module_info(module_id), timeout=remaining)
+        except asyncio.TimeoutError:
+            raise TimeoutError(
+                f"OIDF module {module_id} did not expose terminal info within "
+                f"{timeout_seconds:g}s (last status: {last_status!r})"
+            ) from None
+        if not isinstance(info, dict):
+            raise TypeError("OIDF module info must be a JSON object")
+
+        status = info.get("status")
+        last_status = status
+        if status == "INTERRUPTED":
+            raise RuntimeError(f"OIDF module {module_id} was interrupted")
+        if status == "FAILED":
+            raise RuntimeError(f"OIDF module {module_id} failed")
+        if status == "FINISHED" and info.get("result") is not None:
+            return info
+
+        remaining = deadline - time.monotonic()
+        if remaining <= 0:
+            raise TimeoutError(
+                f"OIDF module {module_id} did not expose terminal info within "
+                f"{timeout_seconds:g}s (last status: {last_status!r})"
+            )
+        await asyncio.sleep(min(poll_interval_seconds, remaining))
+
+
