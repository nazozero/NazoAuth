# Minimal same-origin deployment configuration.
#
# The UI and OAuth/OIDC endpoints are expected to share one public origin:
#   PUBLIC_BASE_URL=https://auth.example.com
#   issuer=https://auth.example.com
#   ui=https://auth.example.com/ui/
#
# Advanced feature, email, federation, observability, and tuning settings are
# documented in docs/configuration.md.

BIND: "0.0.0.0:8000"
PUBLIC_BASE_URL: "http://127.0.0.1:8000"
DATABASE_URL: "postgresql://postgres:postgres@postgres:5432/oauth"
DATABASE_MAX_CONNECTIONS: 32
VALKEY_URL: "redis://valkey:6379/0"
DATA_DIR: "runtime"
AUTHORIZATION_SERVER_PROFILE: "oauth2-baseline"
RUST_LOG: "info"
