BIND: "0.0.0.0:8000"
DATABASE_URL: "postgresql://postgres:postgres@postgres:5432/oauth"
VALKEY_URL: "redis://valkey:6379/0"
VALKEY_COMMAND_TIMEOUT_MS: 1000
ISSUER: "http://127.0.0.1:8000"
FRONTEND_BASE_URL: "http://127.0.0.1:3000"
CORS_ALLOWED_ORIGINS:
  - "http://127.0.0.1:3000"
DEFAULT_AUDIENCE: "resource://default"
AUTHORIZATION_SERVER_PROFILE: "oauth2-baseline"
DPOP_NONCE_POLICY: "required"
REQUEST_OBJECT_JTI_POLICY: "optional"
SESSION_COOKIE_NAME: "nazo_oauth_session"
CSRF_COOKIE_NAME: "nazo_oauth_csrf"
COOKIE_SECURE: false
SESSION_TTL_SECONDS: 28800
AUTH_CODE_TTL_SECONDS: 60
ACCESS_TOKEN_TTL_SECONDS: 300
ID_TOKEN_TTL_SECONDS: 600
REFRESH_TOKEN_TTL_SECONDS: 2592000
AVATAR_MAX_BYTES: 2097152
CLIENT_DELIVERY_TTL_SECONDS: 86400
RATE_LIMIT_WINDOW_SECONDS: 60
AUTH_RATE_LIMIT_MAX_REQUESTS: 30
TOKEN_RATE_LIMIT_MAX_REQUESTS: 60
TOKEN_MANAGEMENT_RATE_LIMIT_MAX_REQUESTS: 120
TRUSTED_PROXY_CIDRS: ""
CLIENT_IP_HEADER_MODE: "none"
SUBJECT_TYPE: "public"
PAIRWISE_SUBJECT_SECRET: ""
PAR_TTL_SECONDS: 90
REQUIRE_PUSHED_AUTHORIZATION_REQUESTS: false
SCIM_BEARER_TOKEN: ""
PASSKEY_RP_ID: "127.0.0.1"
PASSKEY_RP_NAME: "Nazo OAuth"
PASSKEY_ORIGIN: "http://127.0.0.1:8000"
PASSKEY_REQUIRE_USER_VERIFICATION: true
PASSKEY_REQUIRE_USER_HANDLE: true
PASSKEY_STRICT_BASE64: true
FEDERATION_OIDC_PROVIDER_ID: ""
FEDERATION_OIDC_ISSUER: ""
FEDERATION_OIDC_AUTHORIZATION_ENDPOINT: ""
FEDERATION_OIDC_TOKEN_ENDPOINT: ""
FEDERATION_OIDC_JWKS_URL: ""
FEDERATION_OIDC_CLIENT_ID: ""
FEDERATION_OIDC_CLIENT_SECRET: ""
FEDERATION_OIDC_REDIRECT_URI: ""
FEDERATION_OIDC_SCOPES: "openid email profile"
FEDERATION_SAML_GATEWAY_ENABLED: false
FEDERATION_SAML_GATEWAY_ISSUER: ""
FEDERATION_SAML_GATEWAY_AUDIENCE: ""
FEDERATION_SAML_GATEWAY_SECRET: ""
EMAIL_DELIVERY: "disabled"
EMAIL_CODE_TTL_SECONDS: 900
EMAIL_CODE_SEND_COOLDOWN_SECONDS: 60
EMAIL_CODE_PEER_COOLDOWN_SECONDS: 5
EMAIL_SMTP_HOST: "smtp.example.com"
EMAIL_SMTP_PORT: 587
EMAIL_SMTP_TLS: "starttls"
EMAIL_SMTP_USERNAME: "smtp-user"
EMAIL_SMTP_PASSWORD: "smtp-password"
EMAIL_FROM: "Nazo OAuth <no-reply@example.com>"
EMAIL_CODE_DEV_RESPONSE_ENABLED: false
AVATAR_STORAGE_DIR: "/var/lib/nazo_oauth/avatars"
JWK_KEYS_DIR: "/var/lib/nazo_oauth/keys"
SIGNING_EXTERNAL_COMMAND: ""
SIGNING_EXTERNAL_TIMEOUT_MS: 2000
# Feature gates (all default false / closed)
ENABLE_REQUEST_OBJECT: false
ENABLE_REQUEST_URI_PARAMETER: false
ENABLE_PAR_REQUEST_OBJECT: false
ENABLE_AUTHORIZATION_DETAILS: false
ENABLE_LEGACY_AUDIENCE_PARAM: false
RUST_LOG: "info"
OTEL_ENABLED: false
OTEL_EXPORTER_OTLP_ENDPOINT: ""
OTEL_EXPORTER_OTLP_PROTOCOL: "http/protobuf"
OTEL_EXPORTER_OTLP_TIMEOUT: 10000
